{% extends 'base.html.twig' %}

{% block title %}Modifier {{ publication.title }}{% endblock %}

{% block body %}
<div class="form-wrapper">
    <a href="{{ path('app_publication_show', {'id': publication.id}) }}" class="detail-back">Retour</a>
    <div class="form-card">
        <h1 class="form-card__title">Modifier la publication</h1>
        {{ include('publication/_form.html.twig', {'button_label': 'Enregistrer'}) }}
        <div class="form-card__footer">
            {{ include('publication/_delete_form.html.twig') }}
        </div>
    </div>
</div>
{% endblock %}
