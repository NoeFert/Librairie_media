{% extends 'base.html.twig' %}

{% block title %}{{ publication.title }}{% endblock %}

{% block body %}
<div class="detail-wrapper">

    <a href="{{ path('app_publication_index') }}" class="detail-back">Retour aux publications</a>

    <div class="detail-card">
        <div class="detail-card__cover">
            {% if publication.coverUrl %}
                <img src="{{ publication.coverUrl }}" alt="{{ publication.title }}">
            {% else %}
                <div class="detail-card__cover-placeholder">Aucune image</div>
            {% endif %}
        </div>

        <div class="detail-card__body">
            <div class="detail-card__header">
                <h1 class="detail-card__title">{{ publication.title }}</h1>
                {% if publication.media %}
                    <span class="detail-card__badge">{{ publication.media.name }}</span>
                {% endif %}
            </div>

            {% if publication.resume %}
                <p class="detail-card__description">{{ publication.resume }}</p>
            {% endif %}

            {% if publication.numero %}
            <div class="detail-card__meta">
                <div class="detail-card__meta-row">
                    <span class="detail-card__meta-label">Numéro</span>
                    <span class="detail-card__meta-value">{{ publication.numero }}</span>
                </div>
            </div>
            {% endif %}

            <div class="detail-card__actions">
                <a href="{{ path('app_publication_edit', {'id': publication.id}) }}" class="btn btn-secondary">Modifier</a>
                {{ include('publication/_delete_form.html.twig') }}
            </div>
        </div>
    </div>

</div>
{% endblock %}
