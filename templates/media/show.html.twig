{% extends 'base.html.twig' %}

{% block title %}{{ medium.name }}{% endblock %}

{% block body %}
<div class="detail-wrapper">

    <a href="{{ path('app_media_index') }}" class="detail-back">Retour aux médias</a>

    <div class="detail-card">
        <div class="detail-card__body">
            <div class="detail-card__header">
                <div>
                    <div class="detail-card__avatar">{{ medium.name|first|upper }}</div>
                    <h1 class="detail-card__title">{{ medium.name }}</h1>
                </div>
            </div>

            <div class="detail-card__actions">
                <a href="{{ path('app_media_edit', {'id': medium.id}) }}" class="btn btn-secondary">Modifier</a>
                {{ include('media/_delete_form.html.twig') }}
            </div>
        </div>
    </div>

</div>
{% endblock %}
