{% extends 'base.html.twig' %}

{% block title %}Médias{% endblock %}

{% block body %}
<div class="publications-wrapper">

    <div class="publications-header">
        <h1 class="publications-title">Médias</h1>
        <a href="{{ path('app_media_new') }}" class="btn btn-primary">+ Nouveau média</a>
    </div>

    {% if media is empty %}
        <div class="publications-empty">
            <p>Aucun média enregistré.</p>
            <a href="{{ path('app_media_new') }}" class="btn btn-primary">Créer le premier</a>
        </div>
    {% else %}
        <div class="auteur-list">
            {% for medium in media %}
                <div class="auteur-row">
                    <div class="auteur-avatar">{{ medium.name|first|upper }}</div>
                    <div class="auteur-info">
                        <span class="auteur-name">{{ medium.name }}</span>
                    </div>
                    <div class="auteur-actions">
                        <a href="{{ path('app_media_show', {'id': medium.id}) }}" class="btn btn-secondary btn-sm">Voir</a>
                        <a href="{{ path('app_media_edit', {'id': medium.id}) }}" class="btn btn-secondary btn-sm">Modifier</a>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}

</div>
{% endblock %}
