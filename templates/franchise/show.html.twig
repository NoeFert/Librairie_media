{% extends 'base.html.twig' %}

{% block title %}Franchise{% endblock %}

{% block body %}
    <h1>Franchise</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ franchise.id }}</td>
            </tr>
            <tr>
                <th>Name</th>
                <td>{{ franchise.name }}</td>
            </tr>
            <tr>
                <th>Description</th>
                <td>{{ franchise.description }}</td>
            </tr>
            <tr>
                <th>Cover_url</th>
                <td>{{ franchise.coverUrl }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_franchise_index') }}">back to list</a>

    <a href="{{ path('app_franchise_edit', {'id': franchise.id}) }}">edit</a>

    {{ include('franchise/_delete_form.html.twig') }}
{% endblock %}
