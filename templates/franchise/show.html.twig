{% extends 'base.html.twig' %}

{% block title %}Franchise{% endblock %}

{% block body %}
    <h1>Franchise</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ franchise.id }}</td>
            </tr>
            <tr>
                <th>Name</th>
                <td>{{ franchise.name }}</td>
            </tr>
            <tr>
                <th>Description</th>
                <td>{{ franchise.description }}</td>
            </tr>
            <tr>
                <th>Cover_url</th>
                <td>{{ franchise.coverUrl }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_franchise_index') }}">back to list</a>

    <a href="{{ path('app_franchise_edit', {'id': franchise.id}) }}">edit</a>

    {{ include('franchise/_delete_form.html.twig') }}

    <h2>Publications de la franchise</h2>
    {% for publication in publications %}
    <a href="{{ path('app_publication_show', {'id': publication.id}) }}">
        <article class="pub-card">

            <div class="pub-card__cover">
                {% if publication.coverUrl %}
                    <img src="{{ publication.coverUrl }}" alt="{{ publication.title }}">
                {% endif %}
                <div class="pub-card__numero">{{ publication.media.name }}</div>
            </div>

            <div class="pub-card__footer">
                <div class="pub-card__info">
                    <span class="pub-card__title">{{ publication.title }}</span>
                    <span class="pub-card__resume">{{ publication.resume }}</span>
                </div>
            </div>

        </article>
        </a>
        {% else %}
        <div class="publications-empty">
            <p>Aucune publication trouvée.</p>
            <a href="{{ path('app_publication_new') }}" class="btn btn-primary">Créer la première</a>
        </div>
        {% endfor %}
{% endblock %}
