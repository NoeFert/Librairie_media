{% extends 'base.html.twig' %}

{% block title %}{{ franchise.name }}{% endblock %}

{% block body %}
<div class="detail-wrapper">

    <a href="{{ path('app_franchise_index') }}" class="detail-back">Retour aux franchises</a>

    <div class="detail-card">
        <div class="detail-card__cover">
            {% if franchise.coverUrl %}
                <img src="{{ franchise.coverUrl }}" alt="{{ franchise.name }}">
            {% else %}
                <div class="detail-card__cover-placeholder">Aucune image</div>
            {% endif %}
        </div>

        <div class="detail-card__body">
            <div class="detail-card__header">
                <h1 class="detail-card__title">{{ franchise.name }}</h1>
                {% if franchise.genre %}
                    <span class="detail-card__badge">{{ franchise.genre.name }}</span>
                {% endif %}
            </div>

            {% if franchise.description %}
                <p class="detail-card__description">{{ franchise.description }}</p>
            {% endif %}

            <div class="detail-card__actions">
                <a href="{{ path('app_franchise_edit', {'id': franchise.id}) }}" class="btn btn-secondary">Modifier</a>
                {{ include('franchise/_delete_form.html.twig') }}
            </div>
        </div>
    </div>

    <h2 class="section-title">Publications de la franchise</h2>
    <div class="publications-grid">
        {% for publication in publications %}
        <a href="{{ path('app_publication_show', {'id': publication.id}) }}">
            <article class="pub-card">
                <div class="pub-card__cover">
                    {% if publication.coverUrl %}
                        <img src="{{ publication.coverUrl }}" alt="{{ publication.title }}">
                    {% endif %}
                    <div class="pub-card__numero">{{ publication.media.name }}</div>
                </div>
                <div class="pub-card__footer">
                    <div class="pub-card__info">
                        <span class="pub-card__title">{{ publication.title }}</span>
                        <span class="pub-card__resume">{{ publication.resume }}</span>
                    </div>
                </div>
            </article>
        </a>
        {% else %}
        <div class="publications-empty">
            <p>Aucune publication pour cette franchise.</p>
            <a href="{{ path('app_publication_new') }}" class="btn btn-primary">Ajouter une publication</a>
        </div>
        {% endfor %}
    </div>

</div>
{% endblock %}
