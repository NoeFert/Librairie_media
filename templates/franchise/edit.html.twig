{% extends 'base.html.twig' %}

{% block title %}Modifier {{ franchise.name }}{% endblock %}

{% block body %}
<div class="form-wrapper">
    <a href="{{ path('app_franchise_show', {'id': franchise.id}) }}" class="detail-back">Retour</a>
    <div class="form-card">
        <h1 class="form-card__title">Modifier la franchise</h1>
        {{ include('franchise/_form.html.twig', {'button_label': 'Enregistrer'}) }}
        <div class="form-card__footer">
            {{ include('franchise/_delete_form.html.twig') }}
        </div>
    </div>
</div>
{% endblock %}
