{% extends 'base.html.twig' %}

{% block title %}Modifier {{ auteur.name }}{% endblock %}

{% block body %}
<div class="form-wrapper">
    <a href="{{ path('app_auteur_show', {'id': auteur.id}) }}" class="detail-back">Retour</a>
    <div class="form-card">
        <h1 class="form-card__title">Modifier l'auteur</h1>
        {{ include('auteur/_form.html.twig', {'button_label': 'Enregistrer'}) }}
        <div class="form-card__footer">
            {{ include('auteur/_delete_form.html.twig') }}
        </div>
    </div>
</div>
{% endblock %}
