{% extends 'base.html.twig' %}

{% block title %}{{ auteur.name }}{% endblock %}

{% block body %}
<div class="detail-wrapper">

    <a href="{{ path('app_auteur_index') }}" class="detail-back">Retour aux auteurs</a>

    <div class="detail-card">
        <div class="detail-card__body">
            <div class="detail-card__header">
                <div>
                    <div class="detail-card__avatar">{{ auteur.name|first|upper }}</div>
                    <h1 class="detail-card__title">{{ auteur.name }}</h1>
                </div>
                {% if auteur.role %}
                    <span class="detail-card__badge">{{ auteur.role }}</span>
                {% endif %}
            </div>

            <div class="detail-card__actions">
                <a href="{{ path('app_auteur_edit', {'id': auteur.id}) }}" class="btn btn-secondary">Modifier</a>
                {{ include('auteur/_delete_form.html.twig') }}
            </div>
        </div>
    </div>

</div>
{% endblock %}
