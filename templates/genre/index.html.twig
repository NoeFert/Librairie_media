{% extends 'base.html.twig' %}

{% block title %}Genres{% endblock %}

{% block body %}
<div class="publications-wrapper">

    <div class="publications-header">
        <h1 class="publications-title">Genres</h1>
        <a href="{{ path('app_genre_new') }}" class="btn btn-primary">+ Nouveau genre</a>
    </div>

    {% if genres is empty %}
        <div class="publications-empty">
            <p>Aucun genre enregistré.</p>
            <a href="{{ path('app_genre_new') }}" class="btn btn-primary">Créer le premier</a>
        </div>
    {% else %}
        <div class="auteur-list">
            {% for genre in genres %}
                <div class="auteur-row">
                    <div class="auteur-avatar">{{ genre.name|first|upper }}</div>
                    <div class="auteur-info">
                        <span class="auteur-name">{{ genre.name }}</span>
                    </div>
                    <div class="auteur-actions">
                        <a href="{{ path('app_genre_show', {'id': genre.id}) }}" class="btn btn-secondary btn-sm">Voir</a>
                        <a href="{{ path('app_genre_edit', {'id': genre.id}) }}" class="btn btn-secondary btn-sm">Modifier</a>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}

</div>
{% endblock %}
