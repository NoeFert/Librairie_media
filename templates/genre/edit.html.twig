{% extends 'base.html.twig' %}

{% block title %}Modifier {{ genre.name }}{% endblock %}

{% block body %}
<div class="form-wrapper">
    <a href="{{ path('app_genre_show', {'id': genre.id}) }}" class="detail-back">Retour</a>
    <div class="form-card">
        <h1 class="form-card__title">Modifier le genre</h1>
        {{ include('genre/_form.html.twig', {'button_label': 'Enregistrer'}) }}
        <div class="form-card__footer">
            {{ include('genre/_delete_form.html.twig') }}
        </div>
    </div>
</div>
{% endblock %}
